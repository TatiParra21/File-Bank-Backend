generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  password_hash     String
  created_at        DateTime @default(now()) @db.Timestamp(6)
  verified          Boolean
  verification_code String?
}
